# === WebRTC Signaling Server Configuration ===

# Server port (HTTPS)
PORT=3000

# HTTP port (auto-redirects to HTTPS)
HTTP_PORT=3080

# Room access token (leave EMPTY to disable auth)
ROOM_TOKEN=

# Admin API token (leave EMPTY to disable)
ADMIN_TOKEN=

# Maximum viewers per room
MAX_VIEWERS=5

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Recording output directory (inside container)
RECORD_DIR=/data/records
