# === WebRTC Signaling Server Configuration ===

# Server port
PORT=3000

# Room access token (used for authentication)
ROOM_TOKEN=changeme_secret_token

# Admin API token
ADMIN_TOKEN=admin_secret_token

# Maximum viewers per room
MAX_VIEWERS=5

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Default video resolution
DEFAULT_WIDTH=1280
DEFAULT_HEIGHT=720
DEFAULT_FPS=30

# Recording output directory (inside container)
RECORD_DIR=/data/records
